# ============================================================
# Research Mode 配置
# ============================================================
# 当前模式（由 one-report 在每次运行前写入）
RESEARCH_MODE=simple

# ---- Simple 模式（简单任务，3-5 篇）----
RESEARCH_MODE_SIMPLE_MIN_OPENED=3
RESEARCH_MODE_SIMPLE_MAX_OPENED=5
RESEARCH_MODE_SIMPLE_OPEN_TOP_K=2
RESEARCH_MODE_SIMPLE_MIN_RECENT=2

# ---- Medium 模式（中等任务，6-10 篇）----
RESEARCH_MODE_MEDIUM_MIN_OPENED=6
RESEARCH_MODE_MEDIUM_MAX_OPENED=10
RESEARCH_MODE_MEDIUM_OPEN_TOP_K=3
RESEARCH_MODE_MEDIUM_MIN_RECENT=4

# ---- Complex 模式（复杂任务，10-15 篇）----
RESEARCH_MODE_COMPLEX_MIN_OPENED=10
RESEARCH_MODE_COMPLEX_MAX_OPENED=15
RESEARCH_MODE_COMPLEX_OPEN_TOP_K=5
RESEARCH_MODE_COMPLEX_MIN_RECENT=6

# ============================================================
# 运行时变量（由 one-report 根据 RESEARCH_MODE 自动计算写入）
# ============================================================
# MIN_OPENED_PAPERS: 硬性下限——cursor backend 下写 lit_initial.md 前必须达到的最低打开数量
MIN_OPENED_PAPERS=3
# OPEN_TOP_K: 每 query 打开数量
OPEN_TOP_K=2
# MIN_RECENT_PAPERS: 近两年论文下限
MIN_RECENT_PAPERS=2

# ============================================================
# 其他配置（不受 research_mode 影响）
# ============================================================
SEARCH_BACKEND=cursor
REQUIRE_OPEN_LINK=true
DOWNLOAD_OPENED_LITERATURE=true
DOWNLOAD_DIR=data/lit_downloads
